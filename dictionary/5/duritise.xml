        <orth xml:lang="pol">польск. <ref>durzyc</ref>
        </orth>
      </form>
      <sense>
        <def>сбивать с толку, обманывать, дурачить, морочить голову</def>
      </sense>
      <cit type="bibl">
        <bibl>(Do­ rosz. И, 432)</bibl>
      </cit>
