        <bibl>(Pfuhl 213)</bibl>
      </cit>
    </item>
    <item>
      <form>
        <orth xml:lang="dsb">н.-луж. <ref>gjardny</ref>
        </orth>
      </form>
      <sense>
        <def>гордый, надменный, высокомерный</def>
