    <item>
      <form>
        <orth xml:lang="slv">словен. <ref>jedrica</ref> ж. р.</orth>
      </form>
      <sense>
        <def>долька ядра ореха, ядро миндального ореха</def>
      </sense>
      <cit type="bibl">
        <bibl>(Plet. I, 363)</bibl>
      </cit>
    </item>
    <item>
      <form>
        <orth xml:lang="rus">русск. <ref>ядрица</ref> ж. р.</orth>
      </form>
      <sense>
