      </sense>
      <cit type="bibl">
        <bibl>(Plet. I, 110)</bibl>
      </cit>
      <cit type="bibl">
        <bibl>(Pfuhl 87)</bibl>
      </cit>
    </item>
    <item>
      <form>
        <orth xml:lang="dsb">н.-луж. <ref>cfowaty</ref>
        </orth>
      </form>
