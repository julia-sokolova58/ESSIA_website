      </sense>
      <cit type="bibl">
        <bibl>(РСА II, 93)</bibl>
      </cit>
      <cit type="bibl">
        <bibl>(РСА II, 96)</bibl>
      </cit>
    </item>
    <item>
      <form>
        <orth xml:lang="ces">чеш. <ref>bradavka</ref> ж. р.</orth>
      </form>
      <sense>
        <def>бородавка (Ст.-чеш., Прага: нет)</def>
      </sense>
    </item>
    <item>
      <form>
        <orth xml:lang="slk">слвц. <ref>bradavka</ref> то же</orth>
      </form>
