    <item>
      <form>
        <orth xml:lang="srp">сербохорв. <ref>bjesbvati</ref>
        </orth>
      </form>
      <sense>
        <def>insolenter se efferre , бесдвати, 6jecbeamu неистов­ ствовать, спариваться (о собаках, волках)</def>
      </sense>
      <cit type="bibl">
        <bibl>(RJA I, 389)</bibl>
