      </sense>
      <cit type="bibl">
        <bibl>(Plet. I, 243)</bibl>
      </cit>
    </item>
    <item>
      <form>
        <orth xml:lang="ces" type="old">ст.-чеш. <ref>hradiste</ref>
        </orth>
      </form>
      <sense>
