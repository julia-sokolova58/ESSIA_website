<Entry xml:id="gnat">
  <pb n="164" end_page="165" />
  <form type="reconstructed" xml:lang="ocs">
    <orth>*gnatъ</orth>
    <lemma>gnatъ</lemma>
  </form>
  <etym type="cognates">
    <item>
      <form>
        <orth xml:lang="srp">сербохорв. <ref>гтъат</ref> м. р.</orth>
      </form>
