        <bibl>(1379 г., Gebauer I, 87)</bibl>
      </cit>
    </item>
    <item>
      <form>
        <orth xml:lang="ces">чеш. <ref>borovina</ref> ж. р. то же</orth>
      </form>
    </item>
    <item>
      <form>
        <orth xml:lang="slk">слвц. <ref>borovina</ref> ж. р.</orth>
      </form>
      <sense>
        <def>сосновый бор, сосновые ветки</def>
