в <ref type="etymon" target="drebiti">*drebiti</ref>, 
<ref type="etymon" target="drebb">*drebb</ref>, 
<ref type="etymon" target="drebezgb">*drebezgb</ref>, 
<ref type="etymon" target="dreba">*dreba</ref> (см.).</gram>
