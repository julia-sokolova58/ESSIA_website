<Entry xml:id="cerpina">
  <pb n="71" />
  <form type="reconstructed" xml:lang="ocs">
    <orth>*čerpina</orth>
    <lemma>čerpina</lemma>
  </form>
  <etym type="cognates">
    <item>
      <form>
        <orth xml:lang="srp">сербохорв. <ref>crepina</ref> ж. р., увеличит, от crijep</orth>
      </form>
      <sense>
        <def>черепок</def>
      </sense>
      <cit type="bibl">
        <bibl>(RJA I, 821)</bibl>
      </cit>
    </item>
    <item>
      <form>
        <orth xml:lang="slv">словен. <ref>crepina</ref> ж. р.</orth>
      </form>
      <sense>
        <def>черепок, также crepinja ж. р</def>
      </sense>
      <cit type="bibl">
        <bibl>(Plet. I, 110)</bibl>
      </cit>
      <cit type="bibl">
        <bibl>(там же)</bibl>
      </cit>
    </item>
    <item>
      <form>
        <orth xml:lang="ces">чеш. <ref>trepina</ref>, stfepina ж. р.</orth>
      </form>
      <sense>
        <def>черепок</def>
      </sense>
      <cit type="bibl">
        <bibl>(Kott IV, 162)</bibl>
      </cit>
    </item>
    <item>
      <form>
        <orth xml:lang="slk">слвц. <ref>crepina</ref> ж. р.</orth>
      </form>
      <sense>
        <def>черепок, обломок</def>
      </sense>
      <cit type="bibl">
        <bibl>(SSJ I, 222)</bibl>
      </cit>
    </item>
    <item>
      <form>
        <orth xml:lang="rus" type="dialect">русск. диал. <ref>черепйна</ref> ж. р.</orth>
      </form>
      <sense>
        <def>простая негодная посудина, черепок</def>
      </sense>
      <cit type="bibl">
        <bibl>(Говоры Прибалтики 344)</bibl>
      </cit>
    </item>
    <item>
      <form>
        <orth xml:lang="ukr">укр. <ref>черепйнка</ref> ж. р.</orth>
      </form>
      <sense>
        <def>чере­ пок</def>
      </sense>
      <cit type="bibl">
        <bibl>(Гринченко IV, 456)</bibl>
      </cit>
    </item>
  </etym>
  <gramGrp>
    <gram>Производное с суфф.<m type="suffix">
        <ref>-ina</ref>
      </m> от <ref type="etymon" target="segr">*сегръ</ref> (см.).</gram>
  </gramGrp>
</Entry>