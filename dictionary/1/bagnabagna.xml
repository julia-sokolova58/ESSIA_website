    <item>
      <form>
        <orth xml:lang="rus" type="dialect">русск. диал. (<ref>арх</ref>.) багля</orth>
      </form>
      <sense>
        <def>дорога, тропа, выстлан­ ная по раде (болоту) бревешками; бревенчатая мостовая, мостовин- ник</def>
      </sense>
      <cit type="bibl">
        <bibl>( Д а л ь I, 89)</bibl>
