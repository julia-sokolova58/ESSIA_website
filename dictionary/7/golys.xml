        <def>бедняк .—Ср. сюда же суффиксальное производное</def>
      </sense>
      <cit type="bibl">
        <bibl>(Байкоу — Некраш. 77)</bibl>
      </cit>
    </item>
    <item>
      <form>
        <orth xml:lang="bul">болг. <ref>голишаръ</ref> м. р.</orth>
      </form>
      <sense>
        <def>неоперившийся птенец</def>
      </sense>
      <cit type="bibl">
        <bibl>(Геров)</bibl>
      </cit>
      <cit type="bibl">
        <bibl>(Геров — Панчев)</bibl>
