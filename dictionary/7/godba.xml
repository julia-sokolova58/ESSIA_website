        <bibl>(Сл. о мздоим. XVI в., Срезневский I, 608)</bibl>
      </cit>
    </item>
    <item>
      <form>
        <orth xml:lang="rus">русск. <ref>гудьба</ref> ж. р.</orth>
      </form>
