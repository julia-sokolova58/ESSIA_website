      <sense>
        <def>общественное развлечение, беседа, беседка (садо­ вая), крыльцо</def>
      </sense>
    </item>
    <item>
      <form>
        <orth xml:lang="slk">слвц. <ref>besiedka</ref> ж. р.</orth>
