      <cit type="bibl">
        <bibl>(SSJ I, 120)</bibl>
      </cit>
    </item>
    <item>
      <form>
        <orth xml:lang="pol">польск. <ref>borowina</ref> ж. р.</orth>
      </form>
      <sense>
        <def>место, где был сосновый бор, торф, брусника</def>
      </sense>
