        <bibl>(Гринченко TV, 454)</bibl>
      </cit>
    </item>
    <item>
      <form>
        <orth xml:lang="bel">блр. <ref>чараваты</ref>
        </orth>
      </form>
      <sense>
        <def>брюхатый, толстобрю­ хий</def>
