      </form>
      <cit type="bibl">
        <bibl>(Kalal 7l)</bibl>
      </cit>
    </item>
    <item>
      <form>
        <orth xml:lang="ukr">укр. <ref>чепак</ref> м. р.</orth>
      </form>
