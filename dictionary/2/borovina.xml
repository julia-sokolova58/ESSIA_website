      </sense>
      <cit type="bibl">
        <bibl>(Plet. I, 45)</bibl>
      </cit>
    </item>
    <item>
      <form>
        <orth xml:lang="ces" type="old">ст.-чеш. <ref>borovina</ref> ж. р.</orth>
      </form>
      <sense>
