        <bibl>(Gregor. Slowak. von Pilisszanto 224)</bibl>
      </cit>
    </item>
  </etym>
  <gramGrp>
    <gram>Производное с суфф.<m type="suffix">
        <ref>-oba</ref>
      </m> от <ref type="etymon" target="gnus-2">*gnusъ</ref> (см.).</gram>
  </gramGrp>
