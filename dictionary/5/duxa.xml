        <bibl>(па mil duchul, Kott. Dod. k Bart. 19)</bibl>
      </cit>
    </item>
    <item>
      <form>
        <orth xml:lang="ukr" type="dialect">укр. диал. <ref>духа</ref> ж. р.</orth>
      </form>
