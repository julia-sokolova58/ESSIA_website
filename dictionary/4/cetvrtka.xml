      <sense>
        <def>отрезок, ломоть, чет­ верть (напр. хлеба)</def>
      </sense>
      <cit type="bibl">
        <bibl>(Ел. II)</bibl>
      </cit>
    </item>
    <item>
      <form>
        <orth xml:lang="ces">чеш. <ref>ctvrtka</ref> ж. р.</orth>
      </form>
